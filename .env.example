# ---------------------------------------------------------------------------
# AlphaSeeker environment variables
# Copy this file to .env and fill in only the keys for providers you use.
# ---------------------------------------------------------------------------

# LLM provider keys (provider depends on config/models.yaml)
# Required if any configured model starts with "kimi-"
OPENAI_API_KEY=

# Required if any configured model starts with "sf/"
SILICONFLOW_API_KEY=

# Required if any configured model starts with "gemini-"
GOOGLE_API_KEY=

# Data provider keys (optional by route)
# Required for macro indicator fetches from FRED
FRED_API_KEY=

# Required for commodity inventory fetches from EIA
EIA_API_KEY=

# Required for insider-trading fetches (Financial Modeling Prep)
FMP_API_KEY=

# Optional model overrides (examples)
# ALPHASEEKER_MODEL_SUPERVISOR_CLASSIFY=sf/Qwen/Qwen3-8B
# ALPHASEEKER_MODEL_EQUITY_SECTION=kimi-k2.5
